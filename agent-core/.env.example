# =============================================================================
# AgentCore Sales Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the required values.
# Variables marked (required) must be set; others have defaults.
# At startup the agent reads AWS Systems Manager Parameter Store first,
# then falls back to these environment variables for any missing values.
# =============================================================================

# --- OpenSearch Serverless (AOSS) -------------------------------------------

# Collection ID for the OpenSearch Serverless vector-search collection (required)
AOSS_COLLECTION_ID=

# AWS region where the AOSS collection is deployed (required)
AOSS_REGION=

# --- AgentCore Memory --------------------------------------------------------

# Memory resource ID for session persistence (optional).
# In "create" mode this is set automatically by the CDK stack.
# In "external" mode provide the ID of a pre-existing memory resource.
MEMORY_ID=

# --- Amazon Personalize -----------------------------------------------------

# ARN of the Amazon Personalize recommender (optional — recommendations
# are disabled when this is not set)
RECOMMENDER_ARN=

# --- Amazon DynamoDB ---------------------------------------------------------

# Name of the DynamoDB table storing product catalog items
ITEM_TABLE_NAME=item_table

# Name of the DynamoDB table storing user profiles
USER_TABLE_NAME=user_table

# --- Bedrock Model -----------------------------------------------------------

# Bedrock model ID used by the Strands Agent for conversation and summaries
MODEL_ID=us.anthropic.claude-sonnet-4-20250514

# --- AWS Systems Manager Parameter Store ------------------------------------

# Path prefix used to read configuration from Parameter Store at startup.
# The agent fetches all parameters under this prefix in a single API call.
PARAMETER_STORE_PREFIX=/agentcore/sales-agent/

# --- Chat CLI ----------------------------------------------------------------

# Endpoint URL of the deployed AgentCore Runtime agent (used by chat_cli.py)
AGENTCORE_ENDPOINT=
