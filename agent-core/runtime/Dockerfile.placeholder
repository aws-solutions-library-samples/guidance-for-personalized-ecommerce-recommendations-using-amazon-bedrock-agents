# Minimal placeholder Dockerfile for initial deployment
FROM --platform=linux/arm64 python:3.13-slim

# Install curl for health checks
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -u 1000 bedrock_agentcore

# Set working directory
WORKDIR /app

# Create a minimal health check endpoint with proper signal handling
RUN echo 'import signal\n\
import sys\n\
from http.server import HTTPServer, BaseHTTPRequestHandler\n\
\n\
class HealthHandler(BaseHTTPRequestHandler):\n\
    def do_GET(self):\n\
        if self.path == "/health" or self.path == "/":\n\
            self.send_response(200)\n\
            self.send_header("Content-type", "text/plain")\n\
            self.end_headers()\n\
            self.wfile.write(b"OK - Placeholder Runtime")\n\
        else:\n\
            self.send_response(404)\n\
            self.end_headers()\n\
    def log_message(self, format, *args):\n\
        # Suppress access logs to reduce noise\n\
        pass\n\
\n\
server = None\n\
\n\
def signal_handler(sig, frame):\n\
    print("Received signal, shutting down gracefully...")\n\
    if server:\n\
        server.shutdown()\n\
    sys.exit(0)\n\
\n\
if __name__ == "__main__":\n\
    signal.signal(signal.SIGTERM, signal_handler)\n\
    signal.signal(signal.SIGINT, signal_handler)\n\
    \n\
    server = HTTPServer(("0.0.0.0", 8000), HealthHandler)\n\
    print("Placeholder server running on port 8000", flush=True)\n\
    print("Ready to accept connections", flush=True)\n\
    try:\n\
        server.serve_forever()\n\
    except KeyboardInterrupt:\n\
        print("Server stopped")\n\
        server.shutdown()' > /app/placeholder.py

# Change ownership to non-root user
RUN chown -R bedrock_agentcore:bedrock_agentcore /app

# Switch to non-root user
USER bedrock_agentcore

# Expose ports
EXPOSE 8000 8080 9000

# Run placeholder server with unbuffered output
CMD ["python", "-u", "/app/placeholder.py"]
